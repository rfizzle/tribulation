# Shaded-form reference — the detail bar for a 32px HUD/icon glyph.
# A neutral skull rendered with tonal ramps (bone highlight -> ash/smoke midtones -> ink),
# a rim/edge light, and a dark silhouette outline. ~49 colors over only a few base hues:
# "limited palette" means few base HUES, not few tones. Flat single-tone fills read cartoony.
size: 32

legend:
  @ #000000
  $ #020103
  % #e0d2bc
  * #e3d8ba
  + #bdb095
  = #dfd2b6
  o #d3c5aa
