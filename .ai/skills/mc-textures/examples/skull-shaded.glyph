  r #e7ddc5
  s #645841
  t #3f0d0f
  u #383226
  v #807756
  w #897a62
  z #aa9c83
  1 #827965
  2 #cdbea3
  3 #3b392d
  4 #4e4835
  5 #b2a28b
  6 #8d836e
  7 #898067
  8 #db7365
  9 #4d120f
  0 #938975
  A #4b4030
  B #212016
  C #e5dbbf
  D #dd3e38
  E #d34637
  F #736650
  G #5c5441
  . transparent

