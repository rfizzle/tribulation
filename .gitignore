# gradle
.gradle/
build/
out/
classes/

# loom dev runtime (root-level only — anchored so these never match Java
# package directories like src/.../config/ or src/.../logs/)
/run/
/mods/
/logs/
/config/

# IDE
.idea/
*.iml
*.ipr
*.iws
.settings/
.vscode/
.classpath
.project
*.launch

# OS junk
.DS_Store
Thumbs.db

# generated website (built by concord template)
_site/

# local AI / planning state (per concord REPO-LAYOUT standard gitignore)
.claude/settings.local.json
.claude/projects/
.claude/scheduled_tasks.lock
.plan/

# stray runtime artifacts
replay_pid*.log
hs_err_pid*.log

# glyph render output — the .glyph source is committed in art/glyphs/, but the
# master PNG ships in the asset resource tree, so any PNG rendered into
# art/glyphs/ is throwaway (previews land in /tmp).
art/glyphs/*.png
art/glyphs/*.png.mcmeta

# sfx render report — the .sfx source and master .ogg are committed in
# art/audio/, but the waveform/spectrogram report PNG is a throwaway preview.
art/audio/*.report.png
