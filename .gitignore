# concord:gitignore:start
# Concord-managed — synced from concord; edit there, not here. Root-only build,
# runtime, and tooling artifacts are anchored with a leading "/" so they can
# never match a nested package/resource directory of the same name. Put
# repo-specific ignores OUTSIDE this block.

# Gradle / compile output
/.gradle/
/build/
/out/
/bin/
/classes/
/net/

# Loom dev runtime
/run/
/mods/
/logs/
/config/

# Generated website (concord template)
/_site/
# Changelog page is generated at build from changelogs/* + GitHub Releases
/site/pages/changelog.json

# Local AI / planning state
/.plan/
.claude/settings.local.json
.claude/projects/
.claude/scheduled_tasks.lock

# IDE / editor (global — these names never collide with a source dir)
.idea/
.vscode/
.settings/
.classpath
.project
*.iml
*.ipr
*.iws
*.launch

# OS junk
.DS_Store
Thumbs.db

# JVM crash dumps & loom dev-runtime logs (never source; match anywhere)
hs_err_pid*.log
replay_pid*.log
gametest_output.log

# Glyph & SFX pipeline byproducts (mc-textures /glyph, mc-audio /sfx). art/ holds
# the .glyph/.sfx specs — the committed source of truth. Every rendered byproduct
# is throwaway: the shipping master lives in the mod's src/main/resources/assets/
# tree (textures/, sounds/), never in art/. Ignore the renders:
art/glyphs/**/*.png
art/glyphs/**/*.gif
art/glyphs/**/*.mcmeta
art/audio/**/*.ogg
art/audio/**/*.wav
art/audio/**/*.report.png
# concord:gitignore:end
