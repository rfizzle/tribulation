  "nav": "Config",
  "metaTitle": "Config — Tribulation | Difficulty Overhaul for Minecraft",
  "metaDescription": "Complete configuration reference for Tribulation. Every config section, key, type, default, and example JSON for tribulation.json.",
  "ogTitle": "Config — Tribulation",
  "ogDescription": "Full config reference for tribulation.json with all sections, keys, and defaults.",
  "title": "Configuration",
  "lede": "Every Tribulation setting, organized by section. Tune values by hand or reload them live without a restart.",
  "width": "5xl",
  "sections": [
    {
      "title": "File Location &amp; Reload",
      "plainTitle": true,
      "blocks": [
        { "type": "prose", "html": ["The config file is auto-generated with defaults on first launch at:"] },
        { "type": "code", "code": ".minecraft/config/tribulation.json", "bottomGap": true },
        { "type": "prose", "html": ["Server operators can apply changes without a restart with:"] },
        { "type": "code", "code": "/tribulation reload", "tone": "accent2" },
        { "type": "prose", "html": ["Out-of-range numeric values are clamped on load — hand-edited typos are silently corrected. Newly spawned mobs use the updated values; existing mobs keep their current modifiers until they despawn."] }
      ]
    },
    {
      "id": "general",
      "title": "general",
      "intro": "Core settings that control the overall scaling system.",
      "blocks": [
        {
          "type": "table",
          "bottomGap": true,
          "headers": ["Key", "Type", "Default", "Description"],
          "rows": [
            ["<code class='text-accent2 whitespace-nowrap'>maxLevel</code>", "int", "250", "Maximum player difficulty level"],
            ["<code class='text-accent2 whitespace-nowrap'>levelUpTicks</code>", "int", "72000", "Ticks of playtime per level (72000 = 1 hour)"],
            ["<code class='text-accent2 whitespace-nowrap'>mobDetectionRange</code>", "double", "32.0", "Range (blocks) to find the player(s) that drive a mob's scaling"],
            ["<code class='text-accent2 whitespace-nowrap'>scalingMode</code>", "enum", "NEAREST", "Which player level drives a mob when several are in range: <code class='text-accent2'>NEAREST</code>, <code class='text-accent2'>AVERAGE</code>, or <code class='text-accent2'>MAX</code>"],
            ["<code class='text-accent2 whitespace-nowrap'>excludedEntities</code>", "string[]", "[\"the_bumblezone:cosmic_crystal_entity\"]", "Entity IDs exempt from all scaling"],
            ["<code class='text-accent2 whitespace-nowrap'>notifyLevelUp</code>", "boolean", "true", "Show chat message on level up"],
            ["<code class='text-accent2 whitespace-nowrap'>notifyLevelUpShowTier</code>", "boolean", "true", "Include tier info in level-up notification"]
          ]
        },
        { "type": "code", "small": true, "code": "{\n  \"general\": {\n    \"maxLevel\": 250,\n    \"levelUpTicks\": 72000,\n    \"mobDetectionRange\": 32.0,\n    \"scalingMode\": \"NEAREST\",\n    \"excludedEntities\": [\"the_bumblezone:cosmic_crystal_entity\"],\n    \"notifyLevelUp\": true,\n    \"notifyLevelUpShowTier\": true\n  }\n}" }
      ]
    },
    {
      "id": "time-scaling",
